# ── Personal data — NEVER commit ─────────────────────────────────────────────
# Raw exports, derived databases, and anything that could contain your own
# physiology. The whole pipeline is designed so these can be regenerated.
data/raw/
data/raw_cn/
data/raw_us/
data/derived/
data/interim/
*.fit
*.FIT
*.tcx
*.gpx
*.db
*.sqlite
*.sqlite3
*.parquet
*.json.gz
# Garmin auth tokens / secrets
.garminconnect/
.garth/
secrets.toml
secrets.yaml
.env
credentials.json

# ── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
.coverage.*
htmlcov/
*.egg-info/
.eggs/
build/
dist/
.ipynb_checkpoints/

# ── Environments ─────────────────────────────────────────────────────────────
.venv/
venv/
env/

# ── OS / editor ──────────────────────────────────────────────────────────────
.DS_Store
.idea/
.vscode/

# ── Local-only docs — kept off the public repo (project framing + AI planning) ─
docs/PROJECT.md
docs/PLAN.md
docs/superpowers/

# ── Allow-list: keep directory structure + small public fixtures ─────────────
!data/raw/.gitkeep
!data/derived/.gitkeep
!data/interim/.gitkeep
